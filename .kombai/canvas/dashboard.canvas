full bg-[var(--neon-violet)] animate-pulse shadow-[0_0_8px_var(--neon-violet)]\" data-kid=\"1-1-4-0-1-1-0-2-0-1-1\"></span>\n                  </div>\n                </div>\n                <div class=\"p-4 rounded-xl bg-white/[0.02] border border-white/[0.05] space-y-2\" data-kid=\"1-1-4-0-1-1-0-2-1\">\n                  <span class=\"text-[10px] uppercase tracking-widest text-white/30 font-mono\" data-kid=\"1-1-4-0-1-1-0-2-1-0\">ETA Status</span>\n                  <div class=\"flex items-center gap-2\" data-kid=\"1-1-4-0-1-1-0-2-1-1\">\n                    <i class=\"ti ti-clock-bolt text-[var(--cyan-glow)] text-xs\" data-kid=\"1-1-4-0-1-1-0-2-1-1-0\"></i>\n                    <span class=\"text-xs font-bold text-white\" data-kid=\"1-1-4-0-1-1-0-2-1-1-1\">14:32:05 UTC</span>\n                  </div>\n                </div>\n              </div>\n\n              \n              <div class=\"space-y-5 p-6 rounded-2xl bg-[var(--cyan-glow)]/[0.02] border border-[var(--cyan-glow)]/10\" data-kid=\"1-1-4-0-1-1-0-3\">\n                <div class=\"flex justify-between items-end\" data-kid=\"1-1-4-0-1-1-0-3-0\">\n                  <div class=\"space-y-1\" data-kid=\"1-1-4-0-1-1-0-3-0-0\">\n                    <span class=\"text-[10px] uppercase tracking-[0.2em] text-[var(--cyan-glow)]/60 font-space font-bold\" data-kid=\"1-1-4-0-1-1-0-3-0-0-0\">Neural Core Thread 04</span>\n                    <div class=\"text-xl font-bold font-mono\" data-kid=\"1-1-4-0-1-1-0-3-0-0-1\">94.8% <span class=\"text-[10px] font-light text-white/30 ml-2\" data-kid=\"1-1-4-0-1-1-0-3-0-0-1-0\">UTILIZATION</span></div>\n                  </div>\n                  <div class=\"flex gap-1 mb-1\" data-kid=\"1-1-4-0-1-1-0-3-0-1\">\n                    <div class=\"w-1 h-3 bg-[var(--cyan-glow)] rounded-full\" data-kid=\"1-1-4-0-1-1-0-3-0-1-0\"></div>\n                    <div class=\"w-1 h-5 bg-[var(--cyan-glow)] rounded-full\" data-kid=\"1-1-4-0-1-1-0-3-0-1-1\"></div>\n                    <div class=\"w-1 h-2 bg-[var(--cyan-glow)] rounded-full\" data-kid=\"1-1-4-0-1-1-0-3-0-1-2\"></div>\n                  </div>\n                </div>\n                <div class=\"h-2 w-full bg-white/[0.05] rounded-full overflow-hidden p-[2px]\" data-kid=\"1-1-4-0-1-1-0-3-1\">\n                  <div class=\"h-full bg-gradient-to-r from-[var(--cyan-glow)] via-[var(--neon-violet)] to-[var(--cyan-glow)] w-[94.8%] rounded-full shadow-[0_0_15px_rgba(15,255,255,0.4)] animate-[pulse_2s_infinite]\" data-kid=\"1-1-4-0-1-1-0-3-1-0\"></div>\n                </div>\n                <div class=\"flex justify-between text-[9px] font-mono text-white/30 tracking-widest\" data-kid=\"1-1-4-0-1-1-0-3-2\">\n                  <span data-kid=\"1-1-4-0-1-1-0-3-2-0\">PKT_RCV: 142.4 GB</span>\n                  <span data-kid=\"1-1-4-0-1-1-0-3-2-1\">PKT_SND: 2.1 TB</span>\n                </div>\n              </div>\n\n              \n              <div class=\"mt-4 grid grid-cols-2 gap-4\" data-kid=\"1-1-4-0-1-1-0-4\">\n                <button class=\"py-4 bg-white/[0.03] border border-white/[0.08] rounded-xl text-[10px] font-bold hover:bg-white/[0.08] transition-all uppercase tracking-[0.2em] text-white/60\" data-kid=\"1-1-4-0-1-1-0-4-0\">\n                  Suspend Cycle\n                </button>\n                <button class=\"py-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-[10px] font-bold hover:bg-red-500/20 transition-all uppercase tracking-[0.2em]\" data-kid=\"1-1-4-0-1-1-0-4-1\">\n                  Emergency Abort\n                </button>\n              </div>\n            </div>\n          </div>\n        </section>\n\n      </div>\n    </div>\n  </div>\n</div>",
