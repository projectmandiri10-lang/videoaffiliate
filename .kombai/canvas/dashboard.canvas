 fill=\"none\" stroke=\"#DF00FF\" stroke-width=\"1.5\" points=\"0,25 15,22 30,28 45,5 60,8 75,12 90,5 100,10\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"1-2-1-1-2-1-1-2-3-0-0\"></polyline>\n                   </svg>\n                </td>\n                <td class=\"px-6 py-5 text-right\" data-kid=\"1-2-1-1-2-1-1-2-4\">\n                   <button class=\"text-[10px] font-bold text-white/40 hover:text-[#0FFFFF] uppercase tracking-wider transition-colors\" data-kid=\"1-2-1-1-2-1-1-2-4-0\">Details</button>\n                </td>\n              </tr>\n\n              \n              <tr class=\"hover:bg-white/2 transition-colors\" data-kid=\"1-2-1-1-2-1-1-3\">\n                <td class=\"px-6 py-5\" data-kid=\"1-2-1-1-2-1-1-3-0\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"1-2-1-1-2-1-1-3-0-0\">\n                    <div class=\"w-8 h-8 rounded bg-white/5 flex items-center justify-center border border-white/10\" data-kid=\"1-2-1-1-2-1-1-3-0-0-0\">\n                      <i class=\"ti ti-shopping-cart text-lg text-orange-400\" data-kid=\"1-2-1-1-2-1-1-3-0-0-0-0\"></i>\n                    </div>\n                    <span class=\"font-medium font-heading\" data-kid=\"1-2-1-1-2-1-1-3-0-0-1\">Shopee Video</span>\n                  </div>\n                </td>\n                <td class=\"px-6 py-5\" data-kid=\"1-2-1-1-2-1-1-3-1\">\n                   <span class=\"px-2 py-1 rounded-md bg-white/5 border border-white/10 text-white/30 text-[9px] font-bold uppercase tracking-wider\" data-kid=\"1-2-1-1-2-1-1-3-1-0\">Scheduled</span>\n                </td>\n                <td class=\"px-6 py-5 text-white/20 text-[10px]\" data-kid=\"1-2-1-1-2-1-1-3-2\">--</td>\n                <td class=\"px-6 py-5\" data-kid=\"1-2-1-1-2-1-1-3-3\">\n                   <svg class=\"w-24 h-8 opacity-30\" viewBox=\"0 0 100 30\" data-kid=\"1-2-1-1-2-1-1-3-3-0\">\n                      <line x1=\"0\" y1=\"15\" x2=\"100\" y2=\"15\" stroke=\"white\" stroke-width=\"1\" stroke-dasharray=\"2,2\" data-kid=\"1-2-1-1-2-1-1-3-3-0-0\"></line>\n                   </svg>\n                </td>\n                <td class=\"px-6 py-5 text-right\" data-kid=\"1-2-1-1-2-1-1-3-4\">\n                   <button class=\"text-[10px] font-bold text-white/40 hover:text-[#0FFFFF] uppercase tracking-wider transition-colors\" data-kid=\"1-2-1-1-2-1-1-3-4-0\">Priority</button>\n                </td>\n              </tr>\n\n            </tbody>\n          </table>\n        </div>\n\n        \n        <div class=\"mt-16 mb-12 grid grid-cols-4 gap-10\" data-kid=\"1-2-1-1-3\">\n           <div class=\"flex flex-col gap-2\" data-kid=\"1-2-1-1-3-0\">\n              <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-2-1-1-3-0-0\">Compute Cycle</span>\n              <div class=\"flex items-center gap-3\" data-kid=\"1-2-1-1-3-0-1\">\n                 <svg class=\"w-20 h-6\" viewBox=\"0 0 100 30\" data-kid=\"1-2-1-1-3-0-1-0\">\n                    <polyline fill=\"none\" stroke=\"#0FFFFF\" stroke-width=\"1\" points=\"0,15 10,18 20,10 30,20 40,5 50,15 60,12 70,25 80,18 90,22 100,15\" data-kid=\"1-2-1-1-3-0-1-0-0\"></polyline>\n                 </svg>\n                 <span class=\"text-xs font-mono text-[#0FFFFF]\" data-kid=\"1-2-1-1-3-0-1-1\">Stable</span>\n              </div>\n           </div>\n           <div class=\"flex flex-col gap-2\" data-kid=\"1-2-1-1-3-1\">\n              <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-2-1-1-3-1-0\">Network Flow</span>\n              <div class=\"flex items-center gap-3\" data-kid=\"1-2-1-1-3-1-1\">\n                 <svg class=\"w-20 h-6\" viewBox=\"0 0 100 30\" data-kid=\"1-2-1-1-3-1-1-0\">\n                    <polyline fill=\"none\" stroke=\"#DF00FF\" stroke-width=\"1\" points=\"0,25 10,22 20,28 30,15 40,20 50,8 60,12 70,5 80,15 90,10 100,5\" data-kid=\"1-2-1-1-3-1-1-0-0\"></polyline>\n                 </svg>\n                 <span class=\"text-xs font-mono text-green-400\" data-kid=\"1-2-1-1-3-1-1-1\">+12%</span>\n              </div>\n           </div>\n           <div class=\"flex flex-col gap-2\" data-kid=\"1-2-1-1-3-2\">\n              <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-2-1-1-3-2-0\">Storage I/O</span>\n              <div class=\"flex items-center gap-3\" data-kid=\"1-2-1-1-3-2-1\">\n                 <svg class=\"w-20 h-6\" viewBox=\"0 0 100 30\" data-kid=\"1-2-1-1-3-2-1-0\">\n                    <polyline fill=\"none\" stroke=\"white\" stroke-width=\"1\" opacity=\"0.3\" points=\"0,15 10,15 20,15 30,15 40,15 50,15 60,15 70,15 80,15 90,15 100,15\" data-kid=\"1-2-1-1-3-2-1-0-0\"></polyline>\n                 </svg>\n                 <span class=\"text-xs font-mono text-white/40\" data-kid=\"1-2-1-1-3-2-1-1\">Idle</span>\n              </div>\n           </div>\n           <div class=\"flex flex-col gap-2\" data-kid=\"1-2-1-1-3-3\">\n              <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-2-1-1-3-3-0\">Queue Density</span>\n              <div class=\"flex items-center gap-3\" data-kid=\"1-2-1-1-3-3-1\">\n                 <svg class=\"w-20 h-6\" viewBox=\"0 0 100 30\" data-kid=\"1-2-1-1-3-3-1-0\">\n                    <polyline fill=\"none\" stroke=\"#0FFFFF\" stroke-width=\"1\" points=\"0,20 20,15 40,10 60,5 80,2 100,0\" data-kid=\"1-2-1-1-3-3-1-0-0\"></polyline>\n                 </svg>\n                 <span class=\"text-xs font-mono text-[#0FFFFF]\" data-kid=\"1-2-1-1-3-3-1-1\">Rising</span>\n              </div>\n           </div>\n        </div>\n      </section>\n\n    </main>\n  </div>\n</div>",
