      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-bg: #010B13;\n    --color-surface: #1B1B1B;\n    --color-cyan: #0FFFFF;\n    --color-violet: #DF00FF;\n    --color-text-dim: rgba(255, 255, 255, 0.5);\n  }\n\n  .font-heading { font-family: 'Space Grotesk', sans-serif; }\n  .font-body { font-family: 'IBM Plex Sans', sans-serif; }\n\n  /* Glassmorphism Pattern */\n  .glassmorphism {\n    background: rgba(27, 27, 27, 0.4);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);\n  }\n\n  /* Pulse Glow Pattern */\n  @keyframes pulse-glow {\n    0%, 100% { \n      box-shadow: 0 0 8px rgba(15, 255, 255, 0.2), inset 0 0 4px rgba(15, 255, 255, 0.1); \n      border-color: rgba(15, 255, 255, 0.4); \n      transform: scale(1);\n    }\n    50% { \n      box-shadow: 0 0 24px rgba(15, 255, 255, 0.6), inset 0 0 8px rgba(15, 255, 255, 0.2); \n      border-color: rgba(15, 255, 255, 1); \n      transform: scale(1.02);\n    }\n  }\n  .pulse-glow-cyan {\n    animation: pulse-glow 2.5s infinite ease-in-out;\n  }\n\n  @keyframes pulse-glow-violet {\n    0%, 100% { \n      box-shadow: 0 0 8px rgba(223, 0, 255, 0.15), inset 0 0 4px rgba(223, 0, 255, 0.05); \n      border-color: rgba(223, 0, 255, 0.3); \n    }\n    50% { \n      box-shadow: 0 0 20px rgba(223, 0, 255, 0.5), inset 0 0 8px rgba(223, 0, 255, 0.15); \n      border-color: rgba(223, 0, 255, 0.8); \n    }\n  }\n  .pulse-glow-violet {\n    animation: pulse-glow-violet 3s infinite ease-in-out;\n  }\n\n  /* Glass Highlight Pattern */\n  .glass-highlight {\n    position: relative;\n    border: 1px solid rgba(255, 255, 255, 0.06);\n    background: rgba(255, 255, 255, 0.02);\n  }\n  .glass-highlight::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 4px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }\n\n  /* Animated background overlay */\n  .bg-glow {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    z-index: -1;\n    pointer-events: none;\n    overflow: hidden;\n  }\n  .bg-glow .glow-1 {\n    position: absolute;\n    top: 10%;\n    right: 5%;\n    width: 600px;\n    height: 600px;\n    background: radial-gradient(circle, rgba(15, 255, 255, 0.05) 0%, transparent 70%);\n    filter: blur(80px);\n  }\n  .bg-glow .glow-2 {\n    position: absolute;\n    bottom: 0%;\n    left: 10%;\n    width: 500px;\n    height: 500px;\n    background: radial-gradient(circle, rgba(223, 0, 255, 0.05) 0%, transparent 70%);\n    filter: blur(80px);\n  }\n</style>\n\n<div class=\"bg-[#010B13] text-white font-body min-h-[900px] flex overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"bg-glow\" data-kid=\"1-0\">\n    <div class=\"glow-1\" data-kid=\"1-0-0\"></div>\n    <div class=\"glow-2\" data-kid=\"1-0-1\"></div>\n    <video src=\"https://videos.pexels.com/video-files/7101913/7101913-uhd_2560_1440_25fps.mp4\" poster=\"https://images.pexels.com/videos/7101913/abstract-abstract-background-abstract-form-abstract-particles-7101913.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-20\" data-kid=\"1-0-2\"></video>\n  </div>\n\n  \n  <nav class=\"w-16 h-[900px] flex flex-col items-center py-8 gap-8 border-r border-white/5 bg-black/40 backdrop-blur-md z-10\" data-kid=\"1-1\">\n    <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#0FFFFF] to-[#DF00FF] flex items-center justify-center mb-4\" data-kid=\"1-1-0\">\n      <i class=\"ti ti-cpu text-black text-xl\" data-kid=\"1-1-0-0\"></i>\n    </div>\n    <div class=\"flex flex-col gap-6\" data-kid=\"1-1-1\">\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center text-[#0FFFFF] bg-[#0FFFFF]/10 rounded-xl transition-all shadow-[0_0_15px_rgba(15,255,255,0.2)] border border-[#0FFFFF]/30\" data-kid=\"1-1-1-0\">\n        <i class=\"ti ti-layout-2-filled text-xl\" data-kid=\"1-1-1-0-0\"></i>\n      </a>\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center text-white/40 hover:text-white transition-all\" data-kid=\"1-1-1-1\">\n        <i class=\"ti ti-video text-xl\" data-kid=\"1-1-1-1-0\"></i>\n      </a>\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center text-white/40 hover:text-white transition-all\" data-kid=\"1-1-1-2\">\n        <i class=\"ti ti-activity text-xl\" data-kid=\"1-1-1-2-0\"></i>\n      </a>\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center text-white/40 hover:text-white transition-all\" data-kid=\"1-1-1-3\">\n        <i class=\"ti ti-list-details text-xl\" data-kid=\"1-1-1-3-0\"></i>\n      </a>\n    </div>\n    <div class=\"mt-auto flex flex-col gap-6\" data-kid=\"1-1-2\">\n      <a href=\"#\" class=\"p-2 text-white/40 hover:text-white transition-all\" data-kid=\"1-1-2-0\">\n        <i class=\"ti ti-settings text-xl\" data-kid=\"1-1-2-0-0\"></i>\n      </a>\n      <div class=\"w-8 h-8 rounded-full border border-white/20 overflow-hidden\" data-kid=\"1-1-2-1\">\n        <img src=\"https://i.pravatar.cc/100?u=neo\" alt=\"avatar\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"1-1-2-1-0\">\n      </div>\n    </div>\n  </nav>\n\n  \n  <div class=\"flex-1 flex flex-col h-[900px]\" data-kid=\"1-2\">\n    \n    \n    <header class=\"h-16 border-b border-white/5 bg-black/20 backdrop-blur-md flex items-center justify-between px-8 shrink-0\" data-kid=\"1-2-0\">\n      <div class=\"flex items-center gap-4\" data-kid=\"1-2-0-0\">\n        <h1 class=\"font-heading text-xl font-bold tracking-tight\" data-kid=\"1-2-0-0-0\">Jobs <span class=\"text-[#0FFFFF]\" data-kid=\"1-2-0-0-0-0\">Control</span></h1>\n        <div class=\"h-4 w-px bg-white/10 mx-2\" data-kid=\"1-2-0-0-1\"></div>\n        <div class=\"relative group\" data-kid=\"1-2-0-0-2\">\n          <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-white/30 group-focus-within:text-[#0FFFFF]\" data-kid=\"1-2-0-0-2-0\"></i>\n          <input type=\"text\" placeholder=\"Search operational ID...\" class=\"bg-white/5 border border-white/10 rounded-lg pl-10 pr-4 py-1.5 text-sm w-64 focus:outline-none focus:border-[#0FFFFF]/40 transition-all font-body\" data-kid=\"1-2-0-0-2-1\">\n        </div>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"1-2-0-1\">\n        <div class=\"flex items-center gap-2 bg-[#0FFFFF]/5 border border-[#0FFFFF]/20 px-3 py-1.5 rounded-lg\" data-kid=\"1-2-0-1-0\">\n          <span class=\"w-2 h-2 rounded-full bg-[#0FFFFF] animate-pulse\" data-kid=\"1-2-0-1-0-0\"></span>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest text-[#0FFFFF]\" data-kid=\"1-2-0-1-0-1\">System: Online</span>\n        </div>\n        <button class=\"bg-gradient-to-r from-[#DF00FF] to-[#8000FF] hover:brightness-110 text-white px-5 py-2 rounded-xl text-sm font-bold font-heading transition-all shadow-[0_0_20px_rgba(223,0,255,0.4)] flex items-center gap-2 active:scale-95 group\" data-kid=\"1-2-0-1-1\">\n          <i class=\"ti ti-video-plus group-hover:rotate-90 transition-transform duration-300\" data-kid=\"1-2-0-1-1-0\"></i> NEW JOB\n        </button>\n      </div>\n    </header>\n\n    \n    <main class=\"flex-1 flex overflow-hidden\" data-kid=\"1-2-1\">\n      \n      \n      <aside class=\"w-1/3 border-r border-white/5 