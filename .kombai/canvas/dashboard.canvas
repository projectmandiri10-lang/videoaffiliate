      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=IBM+Plex+Sans:wght@300;400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --neon-cyan: #0FFFFF;\n    --neon-violet: #DF00FF;\n    --ink-black: #010B13;\n    --carbon-black: #1B1B1B;\n  }\n\n  body {\n    background-color: var(--ink-black);\n    color: white;\n    font-family: 'IBM Plex Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-heading {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  /* Background Video Container */\n  .bg-particle-field {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    z-index: -1;\n    opacity: 0.5;\n    pointer-events: none;\n  }\n\n  .bg-particle-field::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle at center, transparent 0%, var(--ink-black) 95%);\n    opacity: 0.85;\n  }\n\n  .tech-overlay {\n    position: fixed;\n    inset: 0;\n    background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);\n    background-size: 40px 40px;\n    z-index: -1;\n    pointer-events: none;\n  }\n\n  .bg-particle-field video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n\n  /* Glassmorphism Pattern */\n  .glass-panel {\n    background: rgba(27, 27, 27, 0.45);\n    backdrop-filter: blur(16px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  /* Neon Glow Border Pattern */\n  .neon-glow-cyan {\n    border: 1.5px solid var(--neon-cyan);\n    box-shadow: 0 0 12px rgba(15, 255, 255, 0.2), 0 0 36px rgba(15, 255, 255, 0.06), inset 0 0 10px rgba(15, 255, 255, 0.05);\n  }\n\n  .neon-glow-violet {\n    border: 1.5px solid var(--neon-violet);\n    box-shadow: 0 0 12px rgba(223, 0, 255, 0.2), 0 0 36px rgba(223, 0, 255, 0.06), inset 0 0 10px rgba(223, 0, 255, 0.05);\n  }\n\n  /* Custom Inputs */\n  input[type=range] {\n    -webkit-appearance: none;\n    background: transparent;\n  }\n  input[type=range]::-webkit-slider-runnable-track {\n    width: 100%;\n    height: 4px;\n    background: rgba(255,255,255,0.1);\n    border-radius: 2px;\n  }\n  input[type=range]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    height: 16px;\n    width: 16px;\n    border-radius: 50%;\n    background: var(--slider-color, var(--neon-cyan));\n    cursor: pointer;\n    margin-top: -6px;\n    box-shadow: 0 0 12px var(--slider-color, var(--neon-cyan));\n    border: 2px solid white;\n  }\n\n  .switch {\n    position: relative;\n    display: inline-block;\n    width: 42px;\n    height: 20px;\n  }\n  .switch input { opacity: 0; width: 0; height: 0; }\n  .slider {\n    position: absolute;\n    cursor: pointer;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-color: rgba(255,255,255,0.1);\n    transition: .4s;\n    border-radius: 34px;\n  }\n  .slider:before {\n    position: absolute;\n    content: \"\";\n    height: 14px;\n    width: 14px;\n    left: 3px;\n    bottom: 3px;\n    background-color: white;\n    transition: .4s;\n    border-radius: 50%;\n  }\n  input:checked + .slider { background-color: var(--neon-cyan); }\n  input:checked + .slider:before { transform: translateX(22px); }\n\n  /* Animation for Neon Button */\n  @keyframes shimmer {\n    0% { transform: translateX(-100%); }\n    100% { transform: translateX(100%); }\n  }\n  .btn-neon-glow {\n    position: relative;\n    overflow: hidden;\n    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-violet));\n    box-shadow: 0 0 20px rgba(15, 255, 255, 0.4), 0 0 40px rgba(223, 0, 255, 0.2);\n    transition: all 0.3s ease;\n  }\n  .btn-neon-glow::after {\n    content: \"\";\n    position: absolute;\n    top: 0;\n    left: -100%;\n    width: 100%;\n    height: 100%;\n    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);\n    animation: shimmer 3s infinite;\n  }\n  .btn-neon-glow:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 0 30px rgba(15, 255, 255, 0.6), 0 0 60px rgba(223, 0, 255, 0.4);\n  }\n\n  @keyframes pulse-soft {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.6; }\n  }\n  .pulse-soft { animation: pulse-soft 2s infinite ease-in-out; }\n</style>\n\n<div class=\"relative min-h-[900px] w-full p-8 lg:p-12\" data-kid=\"1\">\n  \n  <div class=\"tech-overlay\" data-kid=\"1-0\"></div>\n  \n  <div class=\"bg-particle-field\" data-kid=\"1-1\">\n    <video src=\"https://videos.pexels.com/video-files/7101913/7101913-uhd_2560_1440_25fps.mp4\" poster=\"https://images.pexels.com/videos/7101913/abstract-abstract-background-abstract-form-abstract-particles-7101913.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" data-kid=\"1-1-0\"></video>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto space-y-12\" data-kid=\"1-2\">\n    \n    \n    <header class=\"flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/5 pb-10\" data-kid=\"1-2-0\">\n      <div class=\"space-y-2\" data-kid=\"1-2-0-0\">\n        <div class=\"flex items-center gap-3 text-sm font-bold tracking-[0.2em] text-[#0FFFFF] uppercase\" data-kid=\"1-2-0-0-0\">\n          <i class=\"ti ti-settings-spark\" data-kid=\"1-2-0-0-0-0\"></i>\n          <span data-kid=\"1-2-0-0-0-1\">Configuration Matrix</span>\n        </div>\n        <h1 class=\"font-heading text-5xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-white/40\" data-kid=\"1-2-0-0-1\">Settings</h1>\n        <p class=\"text-white/40 max-w-2xl text-sm leading-relaxed\" data-kid=\"1-2-0-0-2\">\n          Manage system-wide generation models, neural voice providers, and multi-platform distribution protocols. Automated failover and load balancing are handled at the core level.\n        </p>\n      </div>\n      <button class=\"btn-neon-glow font-heading px-10 py-4 rounded-full font-bold uppercase tracking-widest text-sm flex items-center gap-3\" data-kid=\"1-2-0-1\">\n        <i class=\"ti ti-device-floppy\" data-kid=\"1-2-0-1-0\"></i>\n        Save Configuration\n      </button>\n    </header>\n\n    <main class=\"grid grid-cols-12 gap-8\" data-kid=\"1-2-1\">\n      \n      \n      <section class=\"col-span-12 lg:col-span-4 space-y-6\" data-kid=\"1-2-1-0\">\n        <div class=\"flex items-center gap-3 px-1\" data-kid=\"1-2-1-0-0\">\n          <i class=\"ti ti-binary text-[#0FFFFF]\" data-kid=\"1-2-1-0-0-0\"></i>\n          <h2 class=\"font-heading text-xl font-bold uppercase tracking-wider\" data-kid=\"1-2-1-0-0-1\">System Core</h2>\n        </div>\n\n        <div class=\"space-y-4\" data-kid=\"1-2-1-0-1\">\n          \n          <div class=\"glass-panel rounded-2xl p-6 transition-all duration-300 hover:border-[#0FFFFF]/30 group\" data-kid=\"1-2-1-0-1-0\">\n            <div class=\"flex items-center gap-3 mb-5\" data-kid=\"1-2-1-0-1-0-0\">\n              <div class=\"w-10 h-10 flex items-center justify-center rounded-lg bg-[#0FFFFF]/10 text-[#0FFFFF] group-hover:shadow-[0_0_15px_rgba(15,255,255,0.3)] transition-all\" data-kid=\"1-2-1-0-1-0-0-0\">\n                <i class=\"ti ti-cpu text-xl\" data-kid=\"1-2-1-0-1-0-0-0-0\"></i>\n              </div>\n              <div class=\"flex-1\" data-kid=\"1-2-1-0-1-0-0-1\">\n                <h3 class=\"font-heading text-sm font-bold uppercase tracking-tight\" data-kid=\"1-2-1-0-1-0-0-1-0\">Script Model</h3>\n                <p class=\"text-[10px] text-white/30 uppercase tracking-widest font-bold\" data-kid=\"1-2-1-0-1-0-0-1-1\">LLM Orchestration</p>\n              </div>\n            </div>\n            <div class=\"relative\" data-kid=\"1-2-1-0-1-0-1\">\n              <input type=\"text\" value=\"google/gemini-3-flash-preview\" class=\"w-full bg-black/40 border border-white/5 rounded-xl px-4 py-3 text-sm focus:outline-no