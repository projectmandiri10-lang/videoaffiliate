      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --ink-black: #010B13;\n    --carbon-black: #1B1B1B;\n    --cyan-glow: #0FFFFF;\n    --neon-violet: #DF00FF;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--ink-black);\n    color: white;\n    font-family: 'IBM Plex Sans', sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n  .font-mono { font-family: 'IBM Plex Mono', monospace; }\n\n  /* Glassmorphism Refined */\n  .glass-panel {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    border-radius: 16px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .glass-panel::after {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0; height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12), transparent);\n    z-index: 1;\n  }\n\n  /* Neon Borders Refined */\n  .neon-border-cyan {\n    border: 1px solid rgba(15, 255, 255, 0.25);\n    box-shadow: inset 0 0 10px rgba(15, 255, 255, 0.05), 0 0 15px rgba(15, 255, 255, 0.05);\n  }\n\n  .neon-border-violet {\n    border: 1px solid rgba(223, 0, 255, 0.25);\n    box-shadow: inset 0 0 10px rgba(223, 0, 255, 0.05), 0 0 15px rgba(223, 0, 255, 0.05);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }\n\n  @keyframes pulse-glow {\n    0%, 100% { opacity: 0.8; transform: scale(1); }\n    50% { opacity: 1; transform: scale(1.05); }\n  }\n\n  .pulse-indicator {\n    animation: pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n  }\n</style>\n\n<div class=\"flex min-h-[1000px] bg-[var(--ink-black)] relative\" data-kid=\"1\">\n  \n  <aside id=\"icon-rail\" class=\"w-20 flex flex-col items-center py-10 border-r border-white/[0.05] bg-[var(--carbon-black)]/40 backdrop-blur-2xl shrink-0 z-50\" data-kid=\"1-0\">\n    \n    <div class=\"mb-14 relative group\" data-kid=\"1-0-0\">\n      <div class=\"w-12 h-12 rounded-2xl bg-gradient-to-br from-[var(--cyan-glow)] to-[var(--neon-violet)] flex items-center justify-center shadow-[0_0_20px_rgba(15,255,255,0.4)] group-hover:scale-105 transition-transform duration-500 cursor-pointer\" data-kid=\"1-0-0-0\">\n        <i class=\"ti ti-atom-2 text-black text-2xl font-bold\" data-kid=\"1-0-0-0-0\"></i>\n      </div>\n      <div class=\"absolute -inset-2 bg-[var(--cyan-glow)]/10 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"1-0-0-1\"></div>\n    </div>\n    \n    \n    <nav class=\"flex flex-col gap-9 flex-1\" data-kid=\"1-0-1\">\n      <a href=\"#\" class=\"group relative flex items-center justify-center w-12 h-12 rounded-xl bg-[var(--cyan-glow)]/10 text-[var(--cyan-glow)] transition-all\" data-kid=\"1-0-1-0\">\n        <i class=\"ti ti-smart-home text-2xl\" data-kid=\"1-0-1-0-0\"></i>\n        <div class=\"absolute -left-4 w-1.5 h-6 bg-[var(--cyan-glow)] rounded-r-full shadow-[0_0_10px_var(--cyan-glow)]\" data-kid=\"1-0-1-0-1\"></div>\n      </a>\n      <a href=\"#\" class=\"group flex items-center justify-center w-12 h-12 rounded-xl text-white/40 hover:text-[var(--neon-violet)] hover:bg-[var(--neon-violet)]/10 transition-all\" data-kid=\"1-0-1-1\">\n        <i class=\"ti ti-video text-2xl\" data-kid=\"1-0-1-1-0\"></i>\n      </a>\n      <a href=\"#\" class=\"group flex items-center justify-center w-12 h-12 rounded-xl text-white/40 hover:text-[var(--cyan-glow)] hover:bg-[var(--cyan-glow)]/10 transition-all\" data-kid=\"1-0-1-2\">\n        <i class=\"ti ti-chart-dots text-2xl\" data-kid=\"1-0-1-2-0\"></i>\n      </a>\n      <a href=\"#\" class=\"group flex items-center justify-center w-12 h-12 rounded-xl text-white/40 hover:text-[var(--neon-violet)] hover:bg-[var(--neon-violet)]/10 transition-all\" data-kid=\"1-0-1-3\">\n        <i class=\"ti ti-cpu text-2xl\" data-kid=\"1-0-1-3-0\"></i>\n      </a>\n      <div class=\"w-8 h-px bg-white/5 mx-auto\" data-kid=\"1-0-1-4\"></div>\n      <a href=\"#\" class=\"group flex items-center justify-center w-12 h-12 rounded-xl text-white/40 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"1-0-1-5\">\n        <i class=\"ti ti-layers-subtract text-2xl\" data-kid=\"1-0-1-5-0\"></i>\n      </a>\n    </nav>\n\n    \n    <div class=\"mt-auto flex flex-col gap-8\" data-kid=\"1-0-2\">\n      <a href=\"#\" class=\"flex items-center justify-center w-12 h-12 rounded-xl text-white/30 hover:text-white transition-colors\" data-kid=\"1-0-2-0\">\n        <i class=\"ti ti-settings-spark text-2xl\" data-kid=\"1-0-2-0-0\"></i>\n      </a>\n    </div>\n  </aside>\n\n  \n  <div class=\"flex-1 flex flex-col relative overflow-hidden\" data-kid=\"1-1\">\n    \n    <div class=\"absolute top-0 left-1/4 w-[600px] h-[600px] bg-[var(--cyan-glow)]/5 blur-[160px] rounded-full pointer-events-none\" data-kid=\"1-1-0\"></div>\n    <div class=\"absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-[var(--neon-violet)]/5 blur-[140px] rounded-full pointer-events-none\" data-kid=\"1-1-1\"></div>\n    <img src=\"https://images.unsplash.com/photo-1651505942687-efc26cb528ba?auto=format&w=1280&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-5 pointer-events-none\" alt=\"noise\" data-kid=\"1-1-2\">\n\n    \n    <header class=\"h-24 px-10 flex items-center justify-between z-10 border-b border-white/[0.03] backdrop-blur-md\" data-kid=\"1-1-3\">\n      <div class=\"flex items-center gap-12\" data-kid=\"1-1-3-0\">\n        <div data-kid=\"1-1-3-0-0\">\n          <h1 class=\"font-space text-2xl font-bold tracking-tight flex items-center gap-2\" data-kid=\"1-1-3-0-0-0\">\n            NEON_PARTICLE <span class=\"text-[var(--cyan-glow)] font-light text-base tracking-[0.2em] ml-2\" data-kid=\"1-1-3-0-0-0-0\">LAB.v4</span>\n          </h1>\n          <p class=\"text-[10px] text-white/30 font-mono tracking-widest uppercase mt-0.5\" data-kid=\"1-1-3-0-0-1\">Automated Neural Video Synthesis</p>\n        </div>\n        \n        <div class=\"flex items-center bg-white/[0.03] border border-white/[0.08] rounded-xl px-5 py-2.5 gap-4 w-[480px] focus-within:border-[var(--cyan-glow)]/40 focus-within:bg-white/[0.05] transition-all\" data-kid=\"1-1-3-0-1\">\n          <i class=\"ti ti-search text-white/20\" data-kid=\"1-1-3-0-1-0\"></i>\n          <input type=\"text\" placeholder=\"Access core sequences...\" class=\"bg-transparent border-none outline-hidden text-sm w-full placeholder:text-white/20 font-mono\" data-kid=\"1-1-3-0-1-1\">\n          <div class=\"flex items-center gap-1.5 px-2 py-1 bg-white/5 rounded-md border border-white/10\" data-kid=\"1-1-3-0-1-2\">\n            <span class=\"text-[10px] text-white/40\" data-kid=\"1-1-3-0-1-2-0\">CMD</span>\n            <span class=\"text-[10px] text-white/40\" data-kid=\"1-1-3-0-1-2-1\">K</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-8\" data-kid=\"1-1-3-1\">\n        \n        <div class=\"hidden xl:flex items-center gap-4 bg-black/40 border border-white/5 rounded-2xl px-5 py-2.5\" data-kid=\"1-1-3-1-0\">\n          <div class=\"flex flex-col items-end\" data-kid=\"1-1-3-1-0-0\">\n            <span class=\"text-[10px] font-space font-bold text-[var(--cyan-glow)] tracking-widest uppercase\" data-kid=\"1-1-3-1-0-0-0\">Node: Alpha-9</span>\n            <span class=\"text-[9px] text-white/30 font-mono\" data-kid=\"1-1-3-1-0-0-1\">Uptime: 142h 24m</span>\n          </div>\n          <div class=\"w-10 h-10 rounded-full border border-[var(--cyan-glow)]/20 flex items-center justify-center relative\" data-kid=\"1-1-3-1-0-1\">\n            <div class=\"w-3 h-3 rounded-full bg-[var(--cyan-glow)] pulse-indicator shadow-[0_0_12px_var(--cyan-glow)]\" data-kid=\"1-1-3-1-0-1-0\"></div>\n          </div>\n        </div>\n\n        <div class=\"flex items-center gap-5\" data-kid=\"1-1-3-1-1\">\n           <button class=\"relative w-12 h-12 rounded-xl bg-white/[0.03] border border-white/[0.08] flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-all\" data-kid=\"1-1-3-1-1-0\">\n             <i class=\"ti ti-bell-ringing text-xl\" data-kid=\"1-1-3-1-1-0-0\"></i>\n             <span class=\"absolute top-3 right-3 w-2.5 h-2.5 bg-[var(--neon-violet)] rounded-full border-2 border-[var(--ink-black)] shadow-[0_0_8px_var(--neon-violet)]\" data-kid=\"1-1-3-1-1-0-1\"></span>\n           </button>\n           <div class=\"flex items-center gap-4 p-1.5 pl-4 rounded-2xl bg-white/[0.03] border border-white/[0.08]\" data-kid=\"1-1-3-1-1-1\">\n             <div class=\"flex flex-col items-end mr-1\" data-kid=\"1-1-3-1-1-1-0\">\n               <span class=\"text-xs font-bold text-white/80\" data-kid=\"1-1-3-1-1-1-0-0\">Dr. Aris Thorne</span>\n               <span class=\"text-[10px] text-white/30 uppercase tracking-tighter\" data-kid=\"1-1-3-1-1-1-0-1\">Chief Architect</span>\n             </div>\n             <img src=\"https://i.pravatar.cc/100?u=architect\" class=\"w-10 h-10 rounded-xl border border-white/10 grayscale hover:grayscale-0 transition-all cursor-pointer\" alt=\"avatar\" data-kid=\"1-1-3-1-1-1-1\">\n           </div>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 p-10 overflow-y-auto relative z-10\" data-kid=\"1-1-4\">\n      <div class=\"max-w-7xl mx-auto space-y-12\" data-kid=\"1-1-4-0\">\n        \n        \n        <section id=\"metrics\" class=\"grid grid-cols-12 gap-8\" data-kid=\"1-1-4-0-0\">\n          \n          <div class=\"col-span-12 lg:col-span-7 glass-panel p-10 neon-border-cyan flex items-center justify-between\" data-kid=\"1-1-4-0-0-0\">\n            <div class=\"space-y-10\" data-kid=\"1-1-4-0-0-0-0\">\n              <div data-kid=\"1-1-4-0-0-0-0-0\">\n                <h3 class=\"font-space text-2xl font-bold text-white tracking-tight\" data-kid=\"1-1-4-0-0-0-0-0-0\">Resource Capacity</h3>\n                <p class=\"text-sm text-white/40 mt-1\" data-kid=\"1-1-4-0-0-0-0-0-1\">Real-time neural cluster orchestration</p>\n              </div>\n              <div class=\"flex flex-col gap-6\" data-kid=\"1-1-4-0-0-0-0-1\">\n                <div class=\"flex items-center gap-5 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]\" data-kid=\"1-1-4-0-0-0-0-1-0\">\n                  <div class=\"w-4 h-4 rounded bg-[var(--cyan-glow)] shadow-[0_0_10px_var(--cyan-glow)]\" data-kid=\"1-1-4-0-0-0-0-1-0-0\"></div>\n                  <div data-kid=\"1-1-4-0-0-0-0-1-0-1\">\n                    <div class=\"text-[10px] text-white/40 uppercase tracking-widest font-mono\" data-kid=\"1-1-4-0-0-0-0-1-0-1-0\">Core Clusters</div>\n                    <div class=\"text-2xl font-bold font-space\" data-kid=\"1-1-4-0-0-0-0-1-0-1-1\">842.1 <span class=\"text-xs font-light text-white/30 ml-1\" data-kid=\"1-1-4-0-0-0-0-1-0-1-1-0\">TFLOPS</span></div>\n                  </div>\n                </div>\n                <div class=\"flex items-center gap-5 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]\" data-kid=\"1-1-4-0-0-0-0-1-1\">\n                  <div class=\"w-4 h-4 rounded bg-[var(--neon-violet)] shadow-[0_0_10px_var(--neon-violet)]\" data-kid=\"1-1-4-0-0-0-0-1-1-0\"></div>\n                  <div data-kid=\"1-1-4-0-0-0-0-1-1-1\">\n                    <div class=\"text-[10px] text-white/40 uppercase tracking-widest font-mono\" data-kid=\"1-1-4-0-0-0-0-1-1-1-0\">Bandwidth Load</div>\n                    <div class=\"text-2xl font-bold font-space\" data-kid=\"1-1-4-0-0-0-0-1-1-1-1\">1.2 <span class=\"text-xs font-light text-white/30 ml-1\" data-kid=\"1-1-4-0-0-0-0-1-1-1-1-0\">PB/S</span></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"relative w-64 h-64 flex items-center justify-center\" data-kid=\"1-1-4-0-0-0-1\">\n              <svg class=\"w-full h-full -rotate-90 drop-shadow-[0_0_20px_rgba(0,0,0,0.5)]\" viewBox=\"0 0 100 100\" data-kid=\"1-1-4-0-0-0-1-0\">\n                \n                <circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"4\" data-kid=\"1-1-4-0-0-0-1-0-0\"></circle>\n                <circle cx=\"50\" cy=\"50\" r=\"34\" fill=\"none\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"4\" data-kid=\"1-1-4-0-0-0-1-0-1\"></circle>\n                \n                <circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"var(--cyan-glow)\" stroke-width=\"4\" stroke-dasharray=\"276.4\" stroke-dashoffset=\"60\" stroke-linecap=\"round\" class=\"opacity-80\" data-kid=\"1-1-4-0-0-0-1-0-2\"></circle>\n                \n                <circle cx=\"50\" cy=\"50\" r=\"34\" fill=\"none\" stroke=\"var(--neon-violet)\" stroke-width=\"4\" stroke-dasharray=\"213.6\" stroke-dashoffset=\"85\" stroke-linecap=\"round\" class=\"opacity-80\" data-kid=\"1-1-4-0-0-0-1-0-3\"></circle>\n              </svg>\n              <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"1-1-4-0-0-0-1-1\">\n                <span class=\"text-5xl font-bold font-space text-white\" data-kid=\"1-1-4-0-0-0-1-1-0\">94<span class=\"text-2xl font-light text-white/40\" data-kid=\"1-1-4-0-0-0-1-1-0-0\">%</span></span>\n                <div class=\"flex items-center gap-2 mt-1\" data-kid=\"1-1-4-0-0-0-1-1-1\">\n                  <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-400\" data-kid=\"1-1-4-0-0-0-1-1-1-0\"></div>\n                  <span class=\"text-[10px] uppercase tracking-[0.2em] text-white/40 font-mono\" data-kid=\"1-1-4-0-0-0-1-1-1-1\">Optimal</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"col-span-12 lg:col-span-5 flex flex-col gap-8\" data-kid=\"1-1-4-0-0-1\">\n            <div class=\"glass-panel flex-1 p-8 flex items-center justify-between border-t-2 border-t-[var(--neon-violet)]/40 neon-border-violet\" data-kid=\"1-1-4-0-0-1-0\">\n              <div class=\"space-y-2\" data-kid=\"1-1-4-0-0-1-0-0\">\n                <p class=\"text-[10px] uppercase tracking-[0.2em] text-white/40 font-mono\" data-kid=\"1-1-4-0-0-1-0-0-0\">Render Cycle Index</p>\n                <h4 class=\"text-4xl font-bold font-space\" data-kid=\"1-1-4-0-0-1-0-0-1\">1,248.4<span class=\"text-sm font-light text-white/20 ml-2\" data-kid=\"1-1-4-0-0-1-0-0-1-0\">cycles</span></h4>\n                <div class=\"flex items-center gap-2 text-[var(--cyan-glow)] text-xs font-mono bg-[var(--cyan-glow)]/5 px-2 py-1 rounded w-fit\" data-kid=\"1-1-4-0-0-1-0-0-2\">\n                   <i class=\"ti ti-arrow-up-right\" data-kid=\"1-1-4-0-0-1-0-0-2-0\"></i>\n                   <span data-kid=\"1-1-4-0-0-1-0-0-2-1\">+14.2% EPS</span>\n                </div>\n              </div>\n              <div class=\"w-16 h-16 rounded-2xl bg-[var(--neon-violet)]/10 border border-[var(--neon-violet)]/20 flex items-center justify-center text-[var(--neon-violet)] shadow-[0_0_30px_rgba(223,0,255,0.1)]\" data-kid=\"1-1-4-0-0-1-0-1\">\n                <i class=\"ti ti-zap text-3xl\" data-kid=\"1-1-4-0-0-1-0-1-0\"></i>\n              </div>\n            </div>\n\n            <div class=\"glass-panel flex-1 p-8 flex items-center justify-between border-t-2 border-t-[var(--cyan-glow)]/40 neon-border-cyan\" data-kid=\"1-1-4-0-0-1-1\">\n              <div class=\"space-y-2\" data-kid=\"1-1-4-0-0-1-1