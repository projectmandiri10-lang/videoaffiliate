      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --ink-black: #010B13;\n    --carbon-black: #1B1B1B;\n    --cyan-glow: #0FFFFF;\n    --neon-violet: #DF00FF;\n  }\n\n  body {\n    background-color: var(--ink-black);\n    color: white;\n    font-family: 'IBM Plex Sans', sans-serif;\n    margin: 0;\n    min-height: 900px;\n  }\n\n  .font-heading { font-family: 'Space Grotesk', sans-serif; }\n  .font-body { font-family: 'IBM Plex Sans', sans-serif; }\n\n  /* Pattern: #neon-inset - Refined with distinct resting and active states */\n  .neon-input {\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    background: rgba(255, 255, 255, 0.02);\n    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .neon-input:focus-within {\n    border: 1.5px solid var(--cyan-glow) !important;\n    background: rgba(10, 10, 26, 0.8) !important;\n    box-shadow: 0 0 20px rgba(15, 255, 255, 0.15), inset 0 0 20px rgba(15, 255, 255, 0.05) !important;\n    outline: none !important;\n  }\n\n  /* Pattern: #glassmorphism */\n  .glass-effect {\n    background: rgba(27, 27, 27, 0.45);\n    backdrop-filter: blur(16px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);\n  }\n\n  .cyan-violet-gradient {\n    background: linear-gradient(135deg, var(--cyan-glow) 0%, var(--neon-violet) 100%);\n  }\n\n  .animate-pulse-slow {\n    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n  }\n\n  @keyframes pulse {\n    0%, 100% { opacity: 0.15; transform: scale(1); }\n    50% { opacity: 0.25; transform: scale(1.1); }\n  }\n\n  .scanline {\n    width: 100%;\n    height: 100px;\n    z-index: 1;\n    background: linear-gradient(0deg, rgba(15, 255, 255, 0) 0%, rgba(15, 255, 255, 0.05) 50%, rgba(15, 255, 255, 0) 100%);\n    opacity: 0.1;\n    position: absolute;\n    bottom: 100%;\n    animation: scanline 10s linear infinite;\n  }\n\n  @keyframes scanline {\n    0% { bottom: 100%; }\n    100% { bottom: -100px; }\n  }\n\n  .scanner-line {\n    position: absolute;\n    left: 0;\n    right: 0;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, var(--cyan-glow), transparent);\n    box-shadow: 0 0 15px var(--cyan-glow);\n    z-index: 5;\n    opacity: 0;\n    animation: scanner 4s ease-in-out infinite;\n  }\n\n  @keyframes scanner {\n    0% { top: 0; opacity: 0; }\n    10% { opacity: 0.5; }\n    90% { opacity: 0.5; }\n    100% { top: 100%; opacity: 0; }\n  }\n\n  .grid-bg {\n    background-image: \n      linear-gradient(rgba(15, 255, 255, 0.03) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(15, 255, 255, 0.03) 1px, transparent 1px);\n    background-size: 30px 30px;\n  }\n\n  .particle-bg {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    z-index: 0;\n    opacity: 0.4;\n    overflow: hidden;\n  }\n</style>\n\n<div class=\"relative w-full min-h-[900px] flex items-center justify-center px-4 py-20 overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"particle-bg\" data-kid=\"1-0\">\n    <video src=\"https://videos.pexels.com/video-files/7101913/7101913-uhd_2560_1440_25fps.mp4\" poster=\"https://images.pexels.com/videos/7101913/abstract-abstract-background-abstract-form-abstract-particles-7101913.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover filter grayscale brightness-50 opacity-30\" data-kid=\"1-0-0\"></video>\n  </div>\n  \n  <div class=\"absolute top-0 left-1/4 w-[600px] h-[600px] bg-[var(--neon-violet)]/10 blur-[120px] rounded-full animate-pulse-slow\" data-kid=\"1-1\"></div>\n  <div class=\"absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-[var(--cyan-glow)]/10 blur-[120px] rounded-full animate-pulse-slow\" style=\"animation-delay: -2s;\" data-kid=\"1-2\"></div>\n\n  \n  <main class=\"relative z-10 w-full max-w-[1100px] glass-effect rounded-[32px] flex flex-col lg:flex-row overflow-hidden border border-white/5\" data-kid=\"1-3\">\n    \n    <div class=\"scanline\" data-kid=\"1-3-0\"></div>\n\n    \n    <section class=\"w-full lg:w-5/12 relative flex flex-col items-center justify-center p-12 lg:p-20 border-b lg:border-b-0 lg:border-r border-white/10 bg-gradient-to-br from-[var(--ink-black)] to-[var(--carbon-black)]/40 overflow-hidden\" data-kid=\"1-3-1\">\n      \n      <div class=\"absolute inset-0 grid-bg opacity-30 pointer-events-none\" data-kid=\"1-3-1-0\"></div>\n      \n      <div class=\"absolute inset-0 opacity-15\" data-kid=\"1-3-1-1\">\n        <img src=\"https://images.unsplash.com/photo-1720962158937-7ea890052166?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover scale-150 rotate-12\" decoding=\"async\" loading=\"lazy\" data-kid=\"1-3-1-1-0\">\n      </div>\n\n      <div class=\"relative z-10 text-center -mt-8\" data-kid=\"1-3-1-2\">\n        \n        <div class=\"relative inline-block mb-10 group\" data-kid=\"1-3-1-2-0\">\n          <div class=\"absolute inset-0 bg-[var(--cyan-glow)] blur-[40px] opacity-20 rounded-full group-hover:opacity-40 transition-opacity\" data-kid=\"1-3-1-2-0-0\"></div>\n          <div class=\"relative w-36 h-36 flex items-center justify-center\" data-kid=\"1-3-1-2-0-1\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/processor.svg\" class=\"w-full h-full transition-transform duration-700 group-hover:rotate-90\" style=\"filter: drop-shadow(0 0 15px var(--cyan-glow)) brightness(1.2);\" data-kid=\"1-3-1-2-0-1-0\">\n          </div>\n        </div>\n\n        <h1 class=\"font-heading text-4xl lg:text-5xl font-bold tracking-tight text-white mb-6 leading-[1.1]\" data-kid=\"1-3-1-2-1\">\n          New Automation <span class=\"text-[var(--cyan-glow)]\" data-kid=\"1-3-1-2-1-0\">Sequence</span>\n        </h1>\n        \n        <p class=\"font-body text-white/50 text-lg max-w-sm mx-auto leading-relaxed\" data-kid=\"1-3-1-2-2\">\n          Initialize your AI-driven multi-platform content engine. One master video, infinite reach.\n        </p>\n\n        \n        <div class=\"mt-12 flex flex-wrap justify-center gap-4\" data-kid=\"1-3-1-2-3\">\n          <div class=\"px-4 py-2 rounded-full border border-white/5 bg-white/5 flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/40\" data-kid=\"1-3-1-2-3-0\">\n            <i class=\"ti ti-cpu text-[var(--cyan-glow)]\" data-kid=\"1-3-1-2-3-0-0\"></i>\n            Neural Core Active\n          </div>\n          <div class=\"px-4 py-2 rounded-full border border-white/5 bg-white/5 flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/40\" data-kid=\"1-3-1-2-3-1\">\n            <i class=\"ti ti-zap text-[var(--neon-violet)]\" data-kid=\"1-3-1-2-3-1-0\"></i>\n            Ready to Sync\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[var(--cyan-glow)]/5 to-transparent\" data-kid=\"1-3-1-3\"></div>\n    </section>\n\n    \n    <section class=\"w-full lg:w-7/12 p-8 lg:p-14 bg-black/20\" data-kid=\"1-3-2\">\n      <form class=\"space-y-8\" data-kid=\"1-3-2-0\">\n        \n        <div class=\"group relative\" data-kid=\"1-3-2-0-0\">\n          <label class=\"block font-heading text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-3 ml-1\" data-kid=\"1-3-2-0-0-0\">Video Source Engine</label>\n          <div class=\"relative border border-dashed border-white/10 rounded-2xl p-10 flex flex-col items-center justify-center transition-all duration-500 hover:border-[var(--cyan-glow)]/30 hover:bg-[var(--cyan-glow)]/[0.02] group/dropzone overflow-hidden\" data-kid=\"1-3-2-0-0-1\">\n            <div class=\"scanner-line\" data-kid=\"1-3-2-0-0-1-0\"></div>\n            <div class=\"absolute inset-0 bg-gradient-to-br from-[var(--cyan-glow)]/5 to-transparent opacity-0 group-hover/dropzone:opacity-100 transition-opacity rounded-2xl\" data-kid=\"1-3-2-0-0-1-1\"></div>\n            \n            \n            <div class=\"absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-white/5 group-hover/dropzone:border-[var(--cyan-glow)]/30 transition-colors\" data-kid=\"1-3-2-0-0-1-2\"></div>\n            <div class=\"absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-white/5 group-hover/dropzone:border-[var(--cyan-glow)]/30 transition-colors\" data-kid=\"1-3-2-0-0-1-3\"></div>\n            <div class=\"absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-white/5 group-hover/dropzone:border-[var(--cyan-glow)]/30 transition-colors\" data-kid=\"1-3-2-0-0-1-4\"></div>\n            <div class=\"absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-white/5 group-hover/dropzone:border-[var(--cyan-glow)]/30 transition-colors\" data-kid=\"1-3-2-0-0-1-5\"></div>\n\n            <div class=\"relative z-10 w-16 h-16 rounded-full bg-white/[0.03] border border-white/5 flex items-center justify-center mb-4 group-hover/dropzone:scale-110 group-hover/dropzone:bg-[var(--cyan-glow)]/5 transition-all\" data-kid=\"1-3-2-0-0-1-6\">\n              <i class=\"ti ti-movie text-3xl text-white/10 group-hover/dropzone:text-[var(--cyan-glow)] transition-colors\" data-kid=\"1-3-2-0-0-1-6-0\"></i>\n            </div>\n            \n            <div class=\"relative z-10 text-center\" data-kid=\"1-3-2-0-0-1-7\">\n              <p class=\"font-body text-white/60 font-medium text-base\" data-kid=\"1-3-2-0-0-1-7-0\">Drag and drop your master file</p>\n              <p class=\"font-body text-white/30 text-sm mt-1\" data-kid=\"1-3-2-0-0-1-7-1\">MP4, MOV up to 500MB</p>\n            </div>\n\n            <button type=\"button\" class=\"relative z-10 mt-6 px-6 py-2.5 bg-white/5 hover:bg-white/10 text-xs font-heading font-bold uppercase tracking-widest rounded-lg border border-white/10 transition-all active:scale-95\" data-kid=\"1-3-2-0-0-1-8\">\n              Choose Local Path\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-6\" data-kid=\"1-3-2-0-1\">\n          <div class=\"group\" data-kid=\"1-3-2-0-1-0\">\n            <label class=\"block font-heading text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-3 ml-1\" data-kid=\"1-3-2-0-1-0-0\">Sequence Metadata</label>\n            <div class=\"relative neon-input rounded-xl overflow-hidden focus-within:ring-0\" data-kid=\"1-3-2-0-1-0-1\">\n              <input type=\"text\" placeholder=\"e.g. Summer Collection 2024 Launch\" class=\"w-full px-6 py-4 bg-transparent border-none outline-none text-white font-body placeholder:text-white/10\" data-kid=\"1-3-2-0-1-0-1-0\">\n              <div class=\"absolute right-5 top-1/2 -translate-y-1/2 text-white/10 group-focus-within:text-[var(--cyan-glow)]/40 transition-colors\" data-kid=\"1-3-2-0-1-0-1-1\">\n                <i class=\"ti ti-keyboard\" data-kid=\"1-3-2-0-1-0-1-1-0\"></i>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"group\" data-kid=\"1-3-2-0-1-1\">\n            <label class=\"block font-heading text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-3 ml-1\" data-kid=\"1-3-2-0-1-1-0\">Prompt Logic</label>\n            <div class=\"neon-input rounded-xl overflow-hidden\" data-kid=\"1-3-2-0-1-1-1\">\n              <textarea rows=\"4\" placeholder=\"Briefly explain the video content to guide the AI...\" class=\"w-full px-6 py-4 bg-transparent border-none outline-none text-white font-body placeholder:text-white/10 resize-none\" data-kid=\"1-3-2-0-1-1-1-0\"></textarea>\n            </div>\n          </div>\n\n          <div class=\"group\" data-kid=\"1-3-2-0-1-2\">\n            <label class=\"block font-heading text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-3 ml-1\" data-kid=\"1-3-2-0-1-2-0\">Redirection Path</label>\n            <div class=\"relative neon-input rounded-xl overflow-hidden\" data-kid=\"1-3-2-0-1-2-1\">\n              <div class=\"absolute left-6 top-1/2 -translate-y-1/2 text-white/10 group-focus-within:text-[var(--cyan-glow)]/40 transition-colors\" data-kid=\"1-3-2-0-1-2-1-0\">\n                <i class=\"ti ti-link\" data-kid=\"1-3-2-0-1-2-1-0-0\"></i>\n              </div>\n              <input type=\"url\" placeholder=\"https://shope.ee/your-ref-link\" class=\"w-full pl-14 pr-6 py-4 bg-transparent border-none outline-none text-white font-body placeholder:text-white/10\" data-kid=\"1-3-2-0-1-2-1-1\">\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"pt-4\" data-kid=\"1-3-2-0-2\">\n          <button type=\"submit\" class=\"group relative w-full overflow-hidden rounded-full p-0.5 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-[0_0_30px_rgba(223,0,255,0.2)] hover:shadow-[0_0_40px_rgba(15,255,255,0.4)]\" data-kid=\"1-3-2-0-2-0\">\n            <div class=\"cyan-violet-gradient w-full py-5 flex items-center justify-center gap-3 rounded-full\" data-kid=\"1-3-2-0-2-0-0\">\n              <span class=\"font-heading font-bold text-lg tracking-wide text-[var(--ink-black)] uppercase\" data-kid=\"1-3-2-0-2-0-0-0\">\n                Generate All Platforms\n              </span>\n              <i class=\"ti ti-bolt text-xl text-[var(--ink-black)] animate-pulse\" data-kid=\"1-3-2-0-2-0-0-1\"></i>\n            </div>\n          </button>\n          \n          <div class=\"mt-8 flex items-center justify-center gap-10 opacity-30 group-hover:opacity-60 transition-all\" data-kid=\"1-3-2-0-2-1\">\n             <i class=\"ti ti-brand-tiktok text-2xl hover:text-[var(--cyan-glow)] transition-colors cursor-pointer\" data-kid=\"1-3-2-0-2-1-0\"></i>\n             <i class=\"ti ti-brand-youtube text-2xl hover:text-[var(--neon-violet)] transition-colors cursor-pointer\" data-kid=\"1-3-2-0-2-1-1\"></i>\n             <i class=\"ti ti-brand-facebook text-2xl hover:text-[var(--cyan-glow)] transition-colors cursor-pointer\" data-kid=\"1-3-2-0-2-1-2\"></i>\n             <i class=\"ti ti-brand-shopee text-2xl hover:text-[var(--neon-violet)] transition-colors cursor-pointer\" data-kid=\"1-3-2-0-2-1-3\"></i>\n          </div>\n        </div>\n      </form>\n    </section>\n  </main>\n\n  \n  <div class=\"absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-10 text-[10px] font-heading uppercase tracking-[0.3em] text-white/20\" data-kid=\"1-4\">\n    <div class=\"flex items-center gap-2\" data-kid=\"1-4-0\"><span class=\"w-1.5 h-1.5 rounded-full bg-[var(--cyan-glow)] shadow-[0_0_8px_var(--cyan-glow)]\" data-kid=\"1-4-0-0\"></span> Engine Online</div>\n    <div class=\"flex items-center gap-2\" data-kid=\"1-4-1\"><span class=\"w-1.5 h-1.5 rounded-full bg-[var(--neon-violet)] shadow-[0_0_8px_var(--neon-violet)]\" data-kid=\"1-4-1-0\"></span> Latency 14ms</div>\n    <div class=\"flex items-center gap-2\" data-kid=\"1-4-2\">Build v2.4.0-Stable</div>\n  </div>\n</div>",
